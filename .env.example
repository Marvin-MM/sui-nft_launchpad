# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUI_NETWORK: The Sui network to connect to (mainnet or testnet).
VITE_SUI_NETWORK="testnet"

# PACKAGE_ID: The Sui package ID for the nft_app contract.
VITE_PACKAGE_ID="0x123..."

# MINT_CONFIG_ID: The shared object ID for the mint configuration.
VITE_MINT_CONFIG_ID="0x456..."

# ADMIN_CAP_ID: The AdminCap object ID for the administrator.
VITE_ADMIN_CAP_ID="0x789..."
