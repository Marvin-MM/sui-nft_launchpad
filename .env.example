# ─────────────────────────────────────────────────────────────────────────────
# SUI GENESIS LAUNCHPAD — Environment Variables
#
# Copy this file to .env and fill in all values before running the server.
# NEVER commit your actual .env file to version control.
#
# Required for core functionality:   VITE_PACKAGE_ID, VITE_MINT_CONFIG_ID,
#                                     VITE_TRANSFER_POLICY_ID
# Required for feedback system:       DATABASE_URL, ADMIN_API_KEY
# Required for AI features:           GEMINI_API_KEY  (or ANTHROPIC_API_KEY)
# ─────────────────────────────────────────────────────────────────────────────


# ── Network ───────────────────────────────────────────────────────────────────
# Which Sui network to connect to.  One of: mainnet | testnet | devnet
VITE_SUI_NETWORK=testnet


# ── Core Deployment Objects ───────────────────────────────────────────────────
# These three objects are created when the package is first published.
# Run `sui client publish` and capture the output to fill these in.

# The published package address (starts with 0x)
VITE_PACKAGE_ID=0x

# The shared MintConfig object created by mint::new_collection()
VITE_MINT_CONFIG_ID=0x

# The shared TransferPolicy<SuiNFT> created by royalty::setup_policy()
VITE_TRANSFER_POLICY_ID=0x


# ── Post-Deployment Shared Objects ────────────────────────────────────────────
# These objects are created via separate admin PTBs AFTER package publication.
# Leave blank until each feature is initialised on-chain.

# CommitRevealConfig — created by commit_reveal::create_config()
VITE_COMMIT_REVEAL_CONFIG_ID=0x

# DutchAuction — created by dutch_auction::create_auction()
VITE_DUTCH_AUCTION_ID=0x

# StakingPool — created by staking::setup_pool()
VITE_STAKING_POOL_ID=0x

# RewardMintCap — transferred to deployer from reward_token::init()
# Used by the admin to call reward_vault::init_vault() exactly once
VITE_REWARD_MINT_CAP_ID=0x

# RewardVault — created by reward_vault::init_vault()
# After creation, users can claim staking rewards without admin involvement
VITE_REWARD_VAULT_ID=0x

# UpgradeConfig — created by upgrade::create_config()
VITE_UPGRADE_CONFIG_ID=0x

# RentalPolicy — created by rental::setup_renting()
VITE_RENTAL_POLICY_ID=0x

# ProtectedTP — created alongside RentalPolicy in rental::setup_renting()
# This is the inner TransferPolicy used by the rental extension
VITE_PROTECTED_TP_ID=0x

# MarketplaceConfig — created by marketplace::setup_marketplace()
VITE_MARKETPLACE_CONFIG_ID=0x

# MultiSigAdminCap — created by multisig_admin::create_multisig()
# Share this object for decentralised multi-signer governance
VITE_MULTISIG_ADMIN_CAP_ID=0x


# ── AI Services ───────────────────────────────────────────────────────────────
# Used by src/services/aiService.ts for AI price estimates and summaries.
# At least one key is required for AI features to work.

# Google Gemini API key  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Anthropic Claude API key  (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=


# ── Walrus Decentralised Storage ──────────────────────────────────────────────
# Used by src/services/walrusService.ts to upload NFT media assets.
# The default publisher endpoint works for testnet without a key.

# Walrus publisher API endpoint
# Testnet default: https://publisher.walrus-testnet.walrus.space
# Mainnet: set to your own publisher or a trusted third-party
VITE_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# Walrus aggregator / gateway endpoint (for reading blobs)
# Testnet default: https://aggregator.walrus-testnet.walrus.space
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Number of Walrus storage epochs to purchase per upload (default: 5)
VITE_WALRUS_STORAGE_EPOCHS=5


# ── Database (Prisma + PostgreSQL) ────────────────────────────────────────────
# Required for the feedback system.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# Local development example:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/suigenesis?schema=public"
#
# Hosted providers:
#   Supabase:  https://supabase.com/docs/guides/database/connecting-to-postgres
#   Neon:      https://neon.tech
#   Railway:   https://railway.app
#   PlanetScale (MySQL): change provider to "mysql" in prisma/schema.prisma
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public


# ── Admin API Key ─────────────────────────────────────────────────────────────
# Secret key that protects the admin feedback endpoints:
#   GET  /api/feedback
#   GET  /api/feedback/stats
#   GET  /api/feedback/:id
#   PATCH /api/feedback/:id
#   DELETE /api/feedback/:id
#
# Generate a strong random key, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# The Admin page in the frontend will ask you to enter this key once per
# browser session (stored in sessionStorage only — never in localStorage).
ADMIN_API_KEY=replace-with-a-strong-random-secret


# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on.  Defaults to 3000 if not set.
PORT=3000

# Set to "production" when deploying.  Controls Vite middleware vs static files.
# NODE_ENV=production


# ── Vercel / Deployment (optional) ───────────────────────────────────────────
# If deploying to Vercel, these are set automatically.
# Add VITE_* variables in the Vercel dashboard under Project → Settings → Environment Variables.
# DATABASE_URL and ADMIN_API_KEY go under the same settings as non-VITE secrets.


# ─────────────────────────────────────────────────────────────────────────────
# QUICK START CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────
#
#  1. Copy:         cp .env.example .env
#  2. Publish pkg:  sui client publish --gas-budget 200000000
#  3. Fill in:      VITE_PACKAGE_ID, VITE_MINT_CONFIG_ID, VITE_TRANSFER_POLICY_ID
#  4. Database:     Fill DATABASE_URL, then run:
#                     pnpm db:generate
#                     pnpm db:push
#  5. Admin key:    Set ADMIN_API_KEY to a strong random string
#  6. AI:           Add GEMINI_API_KEY
#  7. Run:          pnpm dev
#
#  Post-deployment setup (one-time admin PTBs):
#   - royalty::setup_policy()         → VITE_TRANSFER_POLICY_ID
#   - staking::setup_pool()           → VITE_STAKING_POOL_ID
#   - reward_vault::init_vault()      → VITE_REWARD_VAULT_ID
#   - marketplace::setup_marketplace()→ VITE_MARKETPLACE_CONFIG_ID
#   - rental::setup_renting()         → VITE_RENTAL_POLICY_ID + VITE_PROTECTED_TP_ID
#   - upgrade::create_config()        → VITE_UPGRADE_CONFIG_ID
#   - dutch_auction::create_auction() → VITE_DUTCH_AUCTION_ID
#   - commit_reveal::create_config()  → VITE_COMMIT_REVEAL_CONFIG_ID
#   - multisig_admin::create_multisig()→ VITE_MULTISIG_ADMIN_CAP_ID
# ─────────────────────────────────────────────────────────────────────────────
