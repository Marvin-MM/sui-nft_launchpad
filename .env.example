# ══════════════════════════════════════════════════════════════════════════════
# Sui NFT Launchpad — Environment Variables
# Copy this file to .env and populate all values before running.
# ══════════════════════════════════════════════════════════════════════════════

# ── Network ──────────────────────────────────────────────────────────────────
VITE_SUI_NETWORK=testnet   # "testnet" | "mainnet"

# ── Core Objects (from `sui client publish` output) ───────────────────────────
VITE_PACKAGE_ID=0x...                # The published package address
VITE_MINT_CONFIG_ID=0x...            # MintConfig shared object (from init PTB)
VITE_TRANSFER_POLICY_ID=0x...        # TransferPolicy<SuiNFT> shared object

# ── Post-Deployment Shared Objects ────────────────────────────────────────────
# These are created in separate admin PTBs AFTER the package is published.
# See the README.md "Post-Deployment Setup" section for the PTB scripts.

# From: commit_reveal::create_config (AdminCap PTB)
VITE_COMMIT_REVEAL_CONFIG_ID=0x...

# From: dutch_auction::create_auction (AdminCap PTB)
VITE_DUTCH_AUCTION_ID=0x...

# From: staking::setup_pool (AdminCap PTB)
VITE_STAKING_POOL_ID=0x...

# From: upgrade::create_config (AdminCap PTB)
VITE_UPGRADE_CONFIG_ID=0x...

# From: rental::setup_renting (AdminCap PTB)
VITE_RENTAL_POLICY_ID=0x...
