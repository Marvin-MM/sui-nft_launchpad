{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "seo:check": "echo '📋 SEO Files Check:' && ls -lah public/{robots.txt,sitemap.xml,manifest.json,sg-logo.svg,humans.txt,SEO-GUIDE.md} && echo '✅ All SEO files present'",
    "seo:audit": "echo '🔍 Run Lighthouse audit: lighthouse https://yourdomain.com --view' && echo '📊 Check Google Search Console: https://search.google.com/search-console' && echo '📱 Test Mobile: https://search.google.com/test/mobile-friendly'",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@google/genai": "^1.29.0",
    "@mysten/dapp-kit": "^1.0.4",
